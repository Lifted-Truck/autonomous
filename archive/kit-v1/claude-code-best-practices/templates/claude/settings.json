{
  "$comment": "Generated by claude-optimization. Hooks make lint/format DETERMINISTIC (run by the harness, not requested of the model). Edit commands to match your repo. The bootstrap fills the hook command strings for your chosen shell.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{FORMAT_LINT_HOOK}}"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{SESSION_START_HOOK}}"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{STOP_HOOK}}"
          }
        ]
      }
    ]
  }
}
